# =============================================================================
# Vitrine Queen Pearls — variables d'environnement
# Copier ce fichier en `.env.local` puis remplir les valeurs.
# `.env.local` est ignoré par git (cf. .gitignore).
# =============================================================================

# --- Base de données (via tunnel SSH local) ----------------------------------
# Ouvrir le tunnel AVANT de lancer l'app :
#   ssh -N -L 3307:127.0.0.1:3306 user@host-distant
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=queen_pearls
DB_PASSWORD=change-me
DB_NAME=queen_pearls

# --- Session admin -----------------------------------------------------------
# Chaîne aléatoire de 32 caractères minimum.
# Générer une valeur sûre :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string-32chars-min

# --- Bootstrap du compte admin initial --------------------------------------
# Utilisés UNE SEULE FOIS par `npm run db:seed` pour créer le premier admin.
# Le mot de passe peut être changé ensuite depuis /admin/parametres.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-please

# --- Divers ------------------------------------------------------------------
# URL publique du site (utilisée pour les metadata OG, sitemaps, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Notifications Discord ---------------------------------------------------
# Webhooks Discord pour les notifications automatiques.
# Créer : Paramètres du salon → Intégrations → Webhooks → Nouveau webhook → Copier l'URL.
# Laisser vide pour désactiver la notification correspondante.
DISCORD_WEBHOOK_RECRUTEMENT=
DISCORD_WEBHOOK_LIVRE_OR=
# Optionnel : webhook dédié aux demandes de partenariat.
# Si vide, les notifications de partenariat utilisent DISCORD_WEBHOOK_RECRUTEMENT.
DISCORD_WEBHOOK_PARTENARIAT=
